# Copia a .env solo en local (nunca subas .env a GitHub)
PORT=7000
KRAKEN_HOST=0.0.0.0

# Proxy opcional (VPN Riseup, SOCKS, etc.)
# PROXY_URL=socks5://127.0.0.1:1080
# PROXY_DEBRID=false

# URL pública manual (si no usas Fly)
# PUBLIC_URL=https://tu-dominio.example

# Palantir — moria (extrae desde moria.cm3 de Kodi con scripts/moria-extract.js)
# PALANTIR_MORIA_DB=C:\ruta\moria.db
# PALANTIR_MORIA_ZM3=C:\ruta\moria.cm3
# PALANTIR_MORIA_ZM3_URL=https://raw.githubusercontent.com/Maniac2017/Mipal2025/main/moria_3_3_9.zm3

# Palantir — API HTTP (avanzado; no hace falta si usas moria)
# PALANTIR_API_BASE=
# PALANTIR_LINKS_PATH=

# AllDebrid (necesario para reproducir enlaces 1fichier de Palantir)
# ALLDEBRID_API_KEY=
